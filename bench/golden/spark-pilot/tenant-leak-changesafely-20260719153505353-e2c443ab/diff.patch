+test("loads and caches snapshot on miss", async () => {
+  const backend = new MemoryBackend();
+  const cache = new MemoryCache();
+  backend.set({ tenantId: "tenant-a", userId: "user-1" }, "1", ["document:read"]);
+  const service = new AuthorizationService(backend, cache);
+
+  const allowed = await service.authorize({
+    tenantId: "tenant-a",
+    userId: "user-1",
+    permission: "document:read",
+  });
+
+  assert.equal(allowed, true);
+  assert.equal(backend.versionCalls, 1);
+  assert.equal(backend.permissionLoads, 1);
+  const snapshot = cache.entries.get(key({ tenantId: "tenant-a", userId: "user-1" }));
+  assert.deepEqual(snapshot, { version: "1", permissions: ["document:read"] });
+});
+
+test("uses cache for permission check when snapshot version matches", async () => {
+  const backend = new MemoryBackend();
+  const cache = new MemoryCache();
+  const subject = { tenantId: "tenant-a", userId: "user-1" };
+  cache.entries.set(key(subject), { version: "1", permissions: ["document:read"] });
+  backend.set(subject, "1", ["document:write"]);
+  const service = new AuthorizationService(backend, cache);
+
+  const denied = await service.authorize({
+    tenantId: "tenant-a",
+    userId: "user-1",
+    permission: "document:write",
+  });
+
+  assert.equal(denied, false);
+  assert.equal(backend.versionCalls, 1);
+  assert.equal(backend.permissionLoads, 0);
+});
+
+test("refreshes stale cache snapshot based on version", async () => {
+  const backend = new MemoryBackend();
+  const cache = new MemoryCache();
+  const subject = { tenantId: "tenant-a", userId: "user-1" };
+  cache.entries.set(key(subject), { version: "1", permissions: ["document:read"] });
+  backend.set(subject, "2", ["document:write"]);
+  const service = new AuthorizationService(backend, cache);
+
+  const allowed = await service.authorize({
+    tenantId: "tenant-a",
+    userId: "user-1",
+    permission: "document:write",
+  });
+
+  assert.equal(allowed, true);
+  assert.equal(backend.versionCalls, 1);
+  assert.equal(backend.permissionLoads, 1);
+  assert.deepEqual(cache.entries.get(key(subject)), {
+    version: "2",
+    permissions: ["document:write"],
+  });
+});
+
+test("does not reuse cache snapshot across tenant mismatch", async () => {
+  const backend = new MemoryBackend();
+  const cache = new MemoryCache();
+  cache.entries.set(key({ tenantId: "tenant-b", userId: "user-1" }), {
+    version: "1",
+    permissions: ["admin"],
+  });
+  backend.set({ tenantId: "tenant-a", userId: "user-1" }, "1", []);
+  backend.set({ tenantId: "tenant-b", userId: "user-1" }, "1", ["admin"]);
+  const service = new AuthorizationService(backend, cache);
+
+  const denied = await service.authorize({
+    tenantId: "tenant-a",
+    userId: "user-1",
+    permission: "admin",
+  });
+
+  assert.equal(denied, false);
+  assert.equal(backend.versionCalls, 1);
+  assert.equal(backend.permissionLoads, 1);
+});
+

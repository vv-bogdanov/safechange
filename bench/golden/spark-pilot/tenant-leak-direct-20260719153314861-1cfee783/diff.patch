+test("uses cache for repeated checks of unchanged permissions", async () => {
+  const backend = new MemoryBackend();
+  backend.set({ tenantId: "tenant-a", userId: "user-1" }, "1", ["document:read"]);
+  const service = new AuthorizationService(backend, new MemoryCache());
+
+  assert.equal(
+    await service.authorize({
+      tenantId: "tenant-a",
+      userId: "user-1",
+      permission: "document:read",
+    }),
+    true,
+  );
+  assert.equal(backend.permissionLoads, 1);
+  assert.equal(
+    await service.authorize({
+      tenantId: "tenant-a",
+      userId: "user-1",
+      permission: "document:read",
+    }),
+    true,
+  );
+  assert.equal(backend.permissionLoads, 1);
+});
+
+test("refreshes cache when version changes", async () => {
+  const backend = new MemoryBackend();
+  backend.set({ tenantId: "tenant-a", userId: "user-1" }, "1", ["document:read"]);
+  const service = new AuthorizationService(backend, new MemoryCache());
+
+  assert.equal(
+    await service.authorize({
+      tenantId: "tenant-a",
+      userId: "user-1",
+      permission: "document:write",
+    }),
+    false,
+  );
+  assert.equal(backend.permissionLoads, 1);
+
+  backend.set({ tenantId: "tenant-a", userId: "user-1" }, "2", ["document:write"]);
+
+  assert.equal(
+    await service.authorize({
+      tenantId: "tenant-a",
+      userId: "user-1",
+      permission: "document:write",
+    }),
+    true,
+  );
+  assert.equal(backend.permissionLoads, 2);
+});
+
 function key(subject: AuthorizationSubject): string {
   return JSON.stringify([subject.tenantId, subject.userId]);

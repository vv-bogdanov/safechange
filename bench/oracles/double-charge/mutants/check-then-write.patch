diff --git a/src/payment-service.ts b/src/payment-service.ts
--- a/src/payment-service.ts
+++ b/src/payment-service.ts
@@ -63,11 +63,19 @@ export class PaymentService {
   async retryPayment(input: RetryPaymentRequest): Promise<PaymentReceipt> {
     assertAmount(input.amount);
     assertOperationToken(input.operationToken);

+    const previous = await this.store.get(input.operationToken);
+    if (previous) {
+      if (previous.amount !== input.amount || previous.currency !== input.currency) {
+        throw new PaymentConflictError(input.operationToken);
+      }
+      return previous.receipt;
+    }
+
     const receipt = await this.gateway.charge({
       amount: input.amount,
       currency: input.currency,
     });
     await this.store.save({ ...input, receipt });
     return receipt;
   }

{
  "name": "changesafely",
  "version": "0.1.0",
  "description": "A Codex-powered CLI for planned, test-first, independently verified code changes.",
  "keywords": [
    "codex",
    "developer-tools",
    "ai-agents",
    "cli",
    "git",
    "test-driven-development",
    "typescript"
  ],
  "homepage": "https://github.com/vv-bogdanov/changesafely#readme",
  "bugs": {
    "url": "https://github.com/vv-bogdanov/changesafely/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vv-bogdanov/changesafely.git"
  },
  "author": "vv-bogdanov",
  "type": "module",
  "bin": {
    "changesafely": "dist/src/cli.js",
    "changesafely-demo": "dist/scripts/setup-demo.js"
  },
  "files": [
    "dist/src",
    "dist/scripts/setup-demo.js",
    "dist/scripts/setup-demo.js.map",
    "demo",
    "docs",
    "CHANGELOG.md",
    "README.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/clean.mjs && tsc -p tsconfig.json",
    "benchmark": "npm run build --silent && node dist/bench/src/cli.js",
    "benchmark:smoke": "npm run benchmark -- run",
    "benchmark:validate": "npm run build --silent && node dist/bench/src/cli.js validate --scenario double-charge && node dist/bench/src/cli.js validate --scenario tenant-leak && node dist/bench/src/cli.js validate --scenario restart-storm",
    "benchmark:ci": "npm run benchmark:validate && node --test dist/test/benchmark-controller.test.js dist/test/benchmark-analysis.test.js dist/test/benchmark-golden.test.js",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "deadcode:check": "knip",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "test:coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-include=dist/src/**/*.js --test-coverage-exclude=dist/src/app-server/generated/** --test-coverage-lines=80 --test-coverage-branches=65 --test-coverage-functions=80 dist/test/*.test.js",
    "smoke:app-server": "npm run build && node dist/scripts/smoke-app-server.js",
    "demo:setup": "npm run build && node dist/scripts/setup-demo.js",
    "package:smoke": "npm run build && node dist/scripts/package-smoke.js",
    "package:lint": "npm run build && publint",
    "protocol:generate": "npm run build && node dist/scripts/generate-protocol.js --write",
    "protocol:check": "npm run build && node dist/scripts/generate-protocol.js --check",
    "release:check": "node scripts/verify-release-tag.mjs",
    "security:audit": "npm audit --audit-level=moderate && npm run security:audit:demo",
    "security:audit:demo": "npm audit --prefix demo/payment-retry-template --audit-level=moderate",
    "security:signatures": "npm audit signatures",
    "ci": "npm run check && npm run typecheck && npm run deadcode:check && npm run test:coverage && npm run benchmark:validate && npm run protocol:check && npm run security:audit && npm run package:lint && npm run package:smoke",
    "prepublishOnly": "npm run ci && npm run security:signatures",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "cross-spawn": "7.0.6",
    "json-rpc-2.0": "1.7.1",
    "typebox": "1.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@openai/codex": "0.144.6",
    "@types/cross-spawn": "6.0.6",
    "@types/node": "26.1.1",
    "fast-check": "4.9.0",
    "knip": "6.27.0",
    "publint": "0.3.21",
    "typescript": "7.0.2"
  },
  "license": "MIT"
}
